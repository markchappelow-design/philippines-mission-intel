name: Daily Philippines Mission Intel Report

import json
from pathlib import Path


def load_source_registry() -> list[dict]:
    path = Path("app/source_registry.json")
    data = json.loads(path.read_text(encoding="utf-8"))
    return [item for item in data if item.get("enabled", True)]


on:
  schedule:
    - cron: "1 0 * * *"
  workflow_dispatch:

jobs:
  build-report:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"

      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip
          pip install -r requirements.txt

      - name: Run report generator
        env:
          OPENAI_API_KEY: ${{ secrets.OPENAI_API_KEY }}
          OPENAI_MODEL: ${{ secrets.OPENAI_MODEL }}
          GOOGLE_DRIVE_TARGET_FOLDER_ID: ${{ secrets.GOOGLE_DRIVE_TARGET_FOLDER_ID }}
          GOOGLE_SERVICE_ACCOUNT_JSON: ${{ secrets.GOOGLE_SERVICE_ACCOUNT_JSON }}
          REPORT_TITLE: Philippines Mission Intel Status Report
          REPORT_PUBLISH_TIME_UTC: "0001"
          SOURCE_CUTOFF_TIME_UTC: "2350"
        run: |
          python -m app.main

      - name: Upload local output artifacts
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: philippines-mission-intel-output
          path: output/

          [
  {
    "source_name": "US Embassy Manila",
    "source_url": "https://ph.usembassy.gov/",
    "section_target": "U.S. Embassy (Manila) travel advisories",
    "reliability_tier": 1,
    "source_type": "webpage",
    "enabled": true,
    "critical": true
  },
