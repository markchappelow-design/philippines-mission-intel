  "trigger_matrix": [
    {
      "indicator": "PLA activity above baseline",
      "threshold": "Multi-domain surge, Bashi Channel activity, amphibious indicators, or explicit blockade/strike indicators",
      "condition_shift": "Amber or Red depending severity",
      "linked_action": "Activate Annex C preparatory or execution block"
    },
    {
      "indicator": "Embassy posture change",
      "threshold": "Demonstration/security alert affecting movement, consular access, or public safety",
      "condition_shift": "Amber",
      "linked_action": "Avoid affected AO; validate lodging and movement COAs"
    },
    {
      "indicator": "State advisory increase",
      "threshold": "New region-specific warning or national advisory escalation",
      "condition_shift": "Amber/Red",
      "linked_action": "Reassess movement; consider early departure"
    },
    {
      "indicator": "Tropical cyclone / severe weather",
      "threshold": "PAR cyclone bulletin, destructive wind risk, flooding, or landslide risk on route",
      "condition_shift": "Amber",
      "linked_action": "Delay movement or shift route/window"
    },
    {
      "indicator": "Volcanic activity",
      "threshold": "PHIVOLCS alert increase, ashfall risk affecting aviation/roads, eruption/lahar warning",
      "condition_shift": "Amber/Red depending area impact",
      "linked_action": "Avoid affected route; verify air/road/port status"
    },
    {
      "indicator": "Air transit disruption",
      "threshold": "Cancellation cluster, airspace closure, airport outage, airline operational disruption",
      "condition_shift": "Amber/Red",
      "linked_action": "Switch to alternate routing or Annex C ground/maritime leg"
    }
  ],
